# --- secrets ---
.env
.env.*
!.env.example
.env.backup*
.env.local
.env.*.local

# --- source material (copyright, do not commit) ---
小说txt/
*.epub
*.mobi
*.pdf
*.fb2
*.azw3

# --- derived data (depends on source material; regenerate via pipeline) ---
data/*
data/proposals/
!data/entity_graph.example.json
!data/style_examples/
data/style_examples/*
!data/style_examples/README.md
outputs/
logs/

# --- multi-book workspaces (iter 017) ---
# Each workspaces/<book>/ holds per-book {小说txt,data,outputs,logs}/.
# All contents are gitignored — same rationale as the legacy paths above.
workspaces/_trash/
workspaces/*/小说txt/
workspaces/*/data/
workspaces/*/outputs/
workspaces/*/logs/
!workspaces/.gitkeep

# --- python build / test artifacts ---
.pycache/
__pycache__/
*.pyc
*.pyo

# --- backups ---
*.bak
*.bak_*

# --- OS junk ---
.DS_Store
Thumbs.db

# --- editor / IDE ---
.idea/
.vscode/
*.swp

# --- Claude Code local config ---
.claude/settings.local.json

# --- playwright debug artifacts ---
.playwright-cli/

# --- unrelated tools (kept locally, not project scope) ---
tools/
